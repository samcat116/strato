# Strato Agent Configuration File
#
# This file configures the Strato hypervisor agent. Command-line arguments
# will override these settings when provided.
#
# Default config file locations:
#   macOS: ~/Library/Application Support/strato/config.toml
#   Linux: /etc/strato/config.toml
# Fallback: ./config.toml (current directory)

# WebSocket URL for connecting to the Control Plane
# Required field - agent cannot start without this
#
# The agent authenticates with a SPIRE-issued X.509 SVID over mutual TLS, so
# this is normally a wss:// URL and the [spiffe] section below is required.
# The agent appends its own name (--agent-id, or the hostname) as the `name`
# query parameter; no credential ever travels in the URL.
control_plane_url = "wss://localhost:8080/agent/ws"

# Directory where QEMU will create domain sockets for VM communication
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/qemu-sockets
#   Linux: /var/run/qemu
# qemu_socket_dir = "/var/run/qemu"

# Logging level: trace, debug, info, notice, warning, error, critical
# Optional - defaults to "info" if not specified
log_level = "info"

# Directory where VM disk images are stored
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/vms
#   Linux: /var/lib/strato/vms
# vm_storage_dir = "/var/lib/strato/vms"

# Directory where managed volume disks and their snapshots are stored.
# The agent derives every volume's location from this root, so when changing
# it on a host that already has volumes, stop the agent and move the existing
# per-volume directories to the new location first — volumes left under the
# old root would be orphaned (deletes look only under the current root).
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/volumes
#   Linux: /var/lib/strato/volumes
# volume_storage_dir = "/var/lib/strato/volumes"

# Image caches. Downloaded VM images (disk images, kernels, rootfs artifacts)
# and materialized sandbox rootfs images are kept on the host so repeat
# launches of the same image skip the download entirely.
#
# Directory for the VM image cache
# Optional - platform-specific defaults:
#   macOS: ~/Library/Caches/strato/images
#   Linux: /var/cache/strato/images
# image_cache_dir = "/var/cache/strato/images"
#
# Size budget for the VM image cache, in GB. When the cache would exceed the
# budget, least-recently-used images are evicted (images used in the last 30
# minutes are never evicted, so an in-progress VM create can briefly push the
# cache over budget). Unset means unbounded.
# image_cache_max_size_gb = 50
#
# Directory for the sandbox (OCI) rootfs image cache
# Optional - platform-specific defaults:
#   macOS: ~/Library/Caches/strato/sandbox-images
#   Linux: /var/cache/strato/sandbox-images
# sandbox_image_cache_dir = "/var/cache/strato/sandbox-images"
#
# Size budget for the sandbox rootfs cache, in GB, enforced the same way — in
# addition to the built-in eviction of entries idle for more than 7 days.
# Unset means bounded only by the idle eviction.
# sandbox_image_cache_max_size_gb = 20

# Path to QEMU binary
# Optional - platform and architecture-specific defaults:
#   macOS arm64: /opt/homebrew/bin/qemu-system-aarch64
#   macOS x86_64: /opt/homebrew/bin/qemu-system-x86_64
#   Linux arm64: /usr/bin/qemu-system-aarch64
#   Linux x86_64: /usr/bin/qemu-system-x86_64
# qemu_binary_path = "/opt/homebrew/bin/qemu-system-aarch64"

# Hardware acceleration for QEMU VMs
# When enabled (the default), VMs are backed by the platform accelerator;
# when disabled, QEMU falls back to TCG emulation (much slower, but useful for
# dev/test on hosts without hardware virtualization). Each option applies to a
# single platform and is ignored on the other.
#   enable_kvm - KVM on Linux   (default: true)
#   enable_hvf - Hypervisor.framework on macOS (default: true)
# enable_kvm = true
# enable_hvf = true

# UEFI firmware paths for disk-based VM boot
# These are used when VMs boot from disk images rather than direct kernel boot.
# Optional - platform and architecture-specific defaults will be used if not set.
#
# ARM64 (aarch64) UEFI firmware:
#   macOS (Homebrew): /opt/homebrew/share/qemu/edk2-aarch64-code.fd
#   Linux (Debian/Ubuntu): /usr/share/AAVMF/AAVMF_CODE.fd
#   Linux (Fedora/RHEL): /usr/share/edk2/aarch64/QEMU_EFI.fd
# firmware_path_arm64 = "/opt/homebrew/share/qemu/edk2-aarch64-code.fd"
#
# x86_64 UEFI firmware (OVMF):
#   macOS (Homebrew): /opt/homebrew/share/qemu/edk2-x86_64-code.fd
#   Linux (Debian/Ubuntu): /usr/share/OVMF/OVMF_CODE.fd
#   Linux (Fedora/RHEL): /usr/share/edk2/ovmf/OVMF_CODE.fd
# firmware_path_x86_64 = "/usr/share/OVMF/OVMF_CODE.fd"

# Firecracker Configuration (Linux only)
# Firecracker is a lightweight VMM for creating microVMs.
# Unlike QEMU, Firecracker requires direct kernel boot (not disk boot).
# These settings are only used on Linux; on macOS, Firecracker is not available.
#
# Path to Firecracker binary
# Optional - defaults are checked in this order:
#   1. /usr/local/bin/firecracker
#   2. /usr/bin/firecracker
#   3. ~/.local/bin/firecracker
# firecracker_binary_path = "/usr/local/bin/firecracker"
#
# Directory where Firecracker creates VM sockets
# Optional - defaults to /tmp/firecracker
# firecracker_socket_dir = "/tmp/firecracker"
#
# Where the sandbox guest base image (kernel + init/guest agent) is installed.
# The agent only advertises the sandbox-runtime capability — making it
# eligible for sandbox (OCI-image microVM) placement — when Firecracker and
# KVM are usable AND something exists at this path.
# Optional - defaults to /var/lib/strato/sandbox/guest
# sandbox_guest_image_path = "/var/lib/strato/sandbox/guest"
#
# Sandbox jailer hardening (issue #425). Sandboxes run untrusted workloads,
# so their Firecracker processes are wrapped in the jailer barrier: chroot,
# privilege drop to a per-sandbox uid/gid, an empty per-sandbox network
# namespace, and (on cgroup-v2 hosts) a memory ceiling.
#   "auto"     - default: jail when the host can (agent running as root and
#                the jailer binary present); otherwise log a warning and run
#                sandboxes unjailed (dev posture).
#   "required" - never run a sandbox unjailed: when the jailer is unusable the
#                agent does not advertise the sandbox capability at all.
#                Recommended for production.
#   "disabled" - never jail (debugging escape hatch).
# sandbox_jailer_mode = "auto"
#
# Path to the jailer binary (ships in the Firecracker release tarball).
# Optional - defaults to "jailer" beside firecracker_binary_path, then
# /usr/local/bin/jailer, /usr/bin/jailer.
# sandbox_jailer_binary_path = "/usr/local/bin/jailer"
#
# Base directory for per-sandbox chroots. Each jail holds a full writable
# rootfs copy, so this lives under VM storage by default.
# Optional - defaults to <vm_storage_dir>/jailer
# sandbox_jailer_chroot_dir = "/var/lib/strato/vms/jailer"
#
# Warm start (issue #426): provision new sandboxes by restoring a
# per-(image, machine shape) template snapshot — booted once to the
# ready-to-launch point — instead of cold-booting the guest every time.
# Every warm failure automatically falls back to a cold boot, so this only
# trades boot latency, never correctness.
# Optional - defaults to true
# sandbox_warm_start = true

# Size budget for the warm-start template snapshot cache, in GB. Entries are
# roughly guest-memory sized and live under <vm_storage_dir>/warm-snapshots.
# Optional - defaults to 20
# sandbox_warm_cache_max_size_gb = 20

# First uid/gid of the per-sandbox range (65536 ids; each sandbox gets a
# deterministic uid derived from its id). Must not collide with real users.
# Optional - defaults to 100000
# sandbox_jailer_uid_base = 100000

# OVN chassis bootstrap (Linux, network_mode = "ovn" only)
#
# ovn-controller only works once the local Open vSwitch carries the chassis
# external_ids (ovn-remote, ovn-encap-type, ovn-encap-ip). The agent ensures
# them at startup: values set here always win, values already present on the
# host are respected, and anything missing gets a default (encap IP is
# auto-detected from the default route). After bootstrapping, the agent
# verifies ovn-controller is actually connected to the southbound database
# and withholds the ovn_networking capability until it is.
#
# Where the OVN southbound database lives. The default assumes ovn-central
# runs on this host; point it at tcp:<central-host>:6642 otherwise.
# ovn_remote = "unix:/var/run/ovn/ovnsb_db.sock"
#
# Where the OVN northbound database lives — the DB the agent writes switches,
# routers, and VM ports into. The default assumes ovn-central runs on this
# host. In a multi-node site (issue #343) every agent points this at the
# site's shared ovn-central (tcp:<central-host>:6641, or ssl:...) together
# with ovn_remote above; only the agent designated as the site's network
# controller in the control plane authors topology there.
# ovn_northbound = "unix:/var/run/ovn/ovnnb_db.sock"
#
# Tunnel encapsulation between hypervisor hosts (default: geneve)
# ovn_encap_type = "geneve"
#
# This host's tunnel endpoint IP. Auto-detected from the default route when
# unset — set it explicitly on multi-homed hosts where VM tunnel traffic
# should use a specific network.
# ovn_encap_ip = "10.0.0.5"
#
# Set to false if an operator or config management owns the chassis
# external_ids and the agent must never touch them.
# ovn_bootstrap_chassis = true

# TLS for an ssl: ovn_northbound endpoint. OVN deployments run a private PKI
# (ovn-pki), so the CA must be given explicitly and ovsdb-server usually
# requires a client certificate signed by the same CA — these mirror
# ovn-nbctl's -C/-c/-p flags. All paths are PEM files. This section is only
# valid when ovn_northbound is ssl:<host>:<port>.
#
# [ovn_northbound_tls]
# ca_cert = "/etc/strato/pki/cacert.pem"       # verifies the server (default: system roots)
# client_cert = "/etc/strato/pki/agent-cert.pem"
# client_key = "/etc/strato/pki/agent-privkey.pem"
# # Verify the server certificate at all (default true; lab setups only)
# verify_server_certificate = true
# # SNI/verification hostname when connecting by IP to a cert issued for a name
# server_hostname = "ovn-central.site.example"

# OVN SNAT uplink (Linux, network_mode = "ovn"). Enables outbound internet for
# networks with external access. SNAT needs a DEDICATED external IP on the
# provider network that the host does NOT own (the OVN router claims it), so it
# is explicit config, not auto-detected. Without this section, routers and
# east-west are realized but no SNAT. The operator connects `bridge` to the
# external network out of band; the agent only wires the OVN side.
#
# Networks are dual-stack by default, so their router ports advertise an IPv6
# default route. Set external_cidr6/gateway6 to give that route somewhere to go —
# without them the v6 SNAT rule is skipped and IPv6 egress black-holes (clients
# with Happy Eyeballs fall back to v4; anything preferring v6 hangs). These are
# additive: external_cidr stays required either way.
#
# [ovn_uplink]
# external_cidr = "203.0.113.2/24"   # dedicated router IP on the provider net
# gateway = "203.0.113.1"            # next hop for the router's default route
# bridge = "br-ex"                   # OVS provider bridge (default br-ex)
# physnet = "physnet-strato"         # OVN physnet mapped to the bridge
# external_cidr6 = "2001:db8::2/64"  # dedicated router IPv6 on the provider net
# gateway6 = "2001:db8::1"           # next hop for the router's ::/0 route

# OVN native dynamic routing (issue #344): advertise floating IPs and tenant
# routes northbound over BGP. Requires OVN >= 25.03 on this host plus an
# operator-configured FRR daemon (with `redistribute connected` in the VRF
# below); OVN itself never speaks BGP. Applied by the site's network
# controller agent to every uplinked router. Disabled (or absent) strips any
# previously applied dynamic-routing options.
#
# [ovn_dynamic_routing]
# enabled = true
# redistribute = ["connected", "nat"] # connected|connected-as-host|static|nat|lb
# vrf_name = "ovnvrf"                 # VRF the advertised routes land in
# maintain_vrf = true                 # let ovn-controller create the VRF netdev
# routing_protocols = ["BGP"]         # protocol traffic punted to host FRR

# Additional configuration options can be added here as needed
# Examples:
# heartbeat_interval = 30
# max_vms = 10

# SPIFFE/SPIRE Configuration — REQUIRED
#
# Mutual TLS with a SPIRE-issued X.509 SVID is the only way the agent
# authenticates to the Control Plane. There is no token-based registration or
# enrollment: without this section (with enabled = true) the agent exits at
# startup. The agent's SPIFFE ID is derived from its name, as
# spiffe://<trust_domain>/agent/<agent-name>, and must have a matching SPIRE
# registration entry.
[spiffe]
enabled = true

# Trust domain for SPIFFE identities (e.g., "strato.local")
trust_domain = "strato.local"

# Source for obtaining SVIDs:
#   "workload_api" - Connect to SPIRE Agent's Workload API (recommended)
#   "files" - Read certificates from files (works with spiffe-helper)
source_type = "workload_api"

# For workload_api source:
# Path to the SPIRE Workload API Unix socket
workload_api_socket_path = "/var/run/spire/sockets/workload.sock"

# For files source:
# Paths to certificate, key, and trust bundle files
# These are typically written by spiffe-helper
# certificate_path = "/var/run/spire/certs/svid.pem"
# private_key_path = "/var/run/spire/certs/svid_key.pem"
# trust_bundle_path = "/var/run/spire/certs/bundle.pem"

# SPIFFE ID the control plane must present on its TLS certificate. The agent
# pins this exact identity: a server whose SVID merely chains to the trust
# bundle (any workload in the trust domain) is refused. Optional — defaults to
# "spiffe://<trust_domain>/control-plane", which is what deploy/compose and the
# Helm chart provision. Set it only if your deployment issues the control
# plane's Envoy a different SVID.
# control_plane_spiffe_id = "spiffe://strato.local/control-plane"

# ---------------------------------------------------------------------------
# Simulation ("dummy agent") mode — for scale-testing a control plane.
#
# When enabled, the agent registers and speaks the full agent protocol
# (register, heartbeat, desired-state reconciliation) but drives a no-op mock
# hypervisor and a no-op mock sandbox runtime with no real networking or
# storage, and reports the configurable fake host capacity below instead of
# probing the machine. This lets a fleet of dummy agents run on one host and
# load-test a control plane far larger than the compute available to run real
# VMs or sandboxes.
#
# The `--simulate` / `--sim-cpus` / `--sim-memory-mb` / `--sim-disk-gb` CLI
# flags override these. See agent/scripts/spawn-sim-fleet.sh to launch a whole
# fleet with a spread of host sizes.
#
# IMPORTANT: never register simulated agents in a control plane / org that also
# has real agents. A simulated agent advertises QEMU, sandbox support, and full
# capacity, so the scheduler and volume selector treat it as a real host — a
# real VM or sandbox could be placed on a dummy (and "run" on the mock while
# nothing executes), or a real volume created on one with a path that does not
# exist. The control plane cannot yet distinguish simulated agents from real
# ones; use a dedicated control plane or org for simulation. Tracked in issue
# #487.
# [simulation]
# enabled = true
#
# # Fake capacity advertised to the scheduler. Unset fields use built-in
# # defaults (8 cores / 16384 MB / 512 GB).
# #
# # All three deplete as VMs are placed and recover as they are deleted, so
# # the scheduler sees a simulated host fill up. Disk accounting needs a
# # control plane that sends `diskBytes` on the VM spec (issue #473); against
# # an older control plane, disk_gb reports full and only CPU/memory bind.
# #
# # Volumes are mocked: simulated agents still attract volume work (they
# # advertise QEMU, and volume placement picks any online agent that supports
# # it), but nothing is written to vm_storage_dir, and image bytes are never
# # fetched. The figures above are therefore unrelated to free space on the
# # machine actually running the fleet.
# cpu_cores = 16
# memory_mb = 65536
# disk_gb = 1024
#
# # Sandbox workloads (issue #470). Simulated agents advertise sandbox support
# # backed by a mock runtime: sandbox placements deplete cpu_cores/memory_mb
# # like VM placements, exec sessions are answered synthetically (non-tty
# # commands echo and exit 0; tty sessions echo stdin until EOF), and each
# # running sandbox emits one synthetic workload log line per interval below,
# # to load-test log shipping. 0 disables emission; unset uses the built-in
# # default (5000 ms).
# sandbox_log_interval_ms = 5000
#
# # When set (> 0), simulated sandbox workloads exit on their own (code 0)
# # this many seconds after boot, exercising the one-shot `Exited` path at
# # scale. Unset/0 (the default) means workloads run until stopped.
# sandbox_exit_after_seconds = 0
