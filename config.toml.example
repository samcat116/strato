# Strato Agent Configuration File
#
# This file configures the Strato hypervisor agent. Command-line arguments
# will override these settings when provided.
#
# Default config file locations:
#   macOS: ~/Library/Application Support/strato/config.toml
#   Linux: /etc/strato/config.toml
# Fallback: ./config.toml (current directory)

# WebSocket URL for connecting to the Control Plane
# Required field - agent cannot start without this
#
# Tip: on a fresh host you usually don't write this file by hand. Run
# `strato-agent join '<registration-url>'` with the URL from the Strato UI
# (Agents -> Create Registration Token); the agent writes a minimal config
# and persists its join state so plain restarts reconnect automatically.
control_plane_url = "ws://localhost:8080/agent/ws"

# Path of the join state file, which stores the rotated reconnect token the
# control plane issues after each successful registration (written mode 0600)
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/agent-state.json
#   Linux: /var/lib/strato/agent-state.json
# state_file = "/var/lib/strato/agent-state.json"

# Directory where QEMU will create domain sockets for VM communication
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/qemu-sockets
#   Linux: /var/run/qemu
# qemu_socket_dir = "/var/run/qemu"

# Logging level: trace, debug, info, notice, warning, error, critical
# Optional - defaults to "info" if not specified
log_level = "info"

# Directory where VM disk images are stored
# Optional - platform-specific defaults:
#   macOS: ~/Library/Application Support/strato/vms
#   Linux: /var/lib/strato/vms
# vm_storage_dir = "/var/lib/strato/vms"

# Path to QEMU binary
# Optional - platform and architecture-specific defaults:
#   macOS arm64: /opt/homebrew/bin/qemu-system-aarch64
#   macOS x86_64: /opt/homebrew/bin/qemu-system-x86_64
#   Linux arm64: /usr/bin/qemu-system-aarch64
#   Linux x86_64: /usr/bin/qemu-system-x86_64
# qemu_binary_path = "/opt/homebrew/bin/qemu-system-aarch64"

# Hardware acceleration for QEMU VMs
# When enabled (the default), VMs are backed by the platform accelerator;
# when disabled, QEMU falls back to TCG emulation (much slower, but useful for
# dev/test on hosts without hardware virtualization). Each option applies to a
# single platform and is ignored on the other.
#   enable_kvm - KVM on Linux   (default: true)
#   enable_hvf - Hypervisor.framework on macOS (default: true)
# enable_kvm = true
# enable_hvf = true

# UEFI firmware paths for disk-based VM boot
# These are used when VMs boot from disk images rather than direct kernel boot.
# Optional - platform and architecture-specific defaults will be used if not set.
#
# ARM64 (aarch64) UEFI firmware:
#   macOS (Homebrew): /opt/homebrew/share/qemu/edk2-aarch64-code.fd
#   Linux (Debian/Ubuntu): /usr/share/AAVMF/AAVMF_CODE.fd
#   Linux (Fedora/RHEL): /usr/share/edk2/aarch64/QEMU_EFI.fd
# firmware_path_arm64 = "/opt/homebrew/share/qemu/edk2-aarch64-code.fd"
#
# x86_64 UEFI firmware (OVMF):
#   macOS (Homebrew): /opt/homebrew/share/qemu/edk2-x86_64-code.fd
#   Linux (Debian/Ubuntu): /usr/share/OVMF/OVMF_CODE.fd
#   Linux (Fedora/RHEL): /usr/share/edk2/ovmf/OVMF_CODE.fd
# firmware_path_x86_64 = "/usr/share/OVMF/OVMF_CODE.fd"

# Firecracker Configuration (Linux only)
# Firecracker is a lightweight VMM for creating microVMs.
# Unlike QEMU, Firecracker requires direct kernel boot (not disk boot).
# These settings are only used on Linux; on macOS, Firecracker is not available.
#
# Path to Firecracker binary
# Optional - defaults are checked in this order:
#   1. /usr/local/bin/firecracker
#   2. /usr/bin/firecracker
#   3. ~/.local/bin/firecracker
# firecracker_binary_path = "/usr/local/bin/firecracker"
#
# Directory where Firecracker creates VM sockets
# Optional - defaults to /tmp/firecracker
# firecracker_socket_dir = "/tmp/firecracker"
#
# Where the sandbox guest base image (kernel + init/guest agent) is installed.
# The agent only advertises the sandbox-runtime capability — making it
# eligible for sandbox (OCI-image microVM) placement — when Firecracker and
# KVM are usable AND something exists at this path.
# Optional - defaults to /var/lib/strato/sandbox/guest
# sandbox_guest_image_path = "/var/lib/strato/sandbox/guest"

# OVN chassis bootstrap (Linux, network_mode = "ovn" only)
#
# ovn-controller only works once the local Open vSwitch carries the chassis
# external_ids (ovn-remote, ovn-encap-type, ovn-encap-ip). The agent ensures
# them at startup: values set here always win, values already present on the
# host are respected, and anything missing gets a default (encap IP is
# auto-detected from the default route). After bootstrapping, the agent
# verifies ovn-controller is actually connected to the southbound database
# and withholds the ovn_networking capability until it is.
#
# Where the OVN southbound database lives. The default assumes ovn-central
# runs on this host; point it at tcp:<central-host>:6642 otherwise.
# ovn_remote = "unix:/var/run/ovn/ovnsb_db.sock"
#
# Where the OVN northbound database lives — the DB the agent writes switches,
# routers, and VM ports into. The default assumes ovn-central runs on this
# host. In a multi-node site (issue #343) every agent points this at the
# site's shared ovn-central (tcp:<central-host>:6641, or ssl:...) together
# with ovn_remote above; only the agent designated as the site's network
# controller in the control plane authors topology there.
# ovn_northbound = "unix:/var/run/ovn/ovnnb_db.sock"
#
# Tunnel encapsulation between hypervisor hosts (default: geneve)
# ovn_encap_type = "geneve"
#
# This host's tunnel endpoint IP. Auto-detected from the default route when
# unset — set it explicitly on multi-homed hosts where VM tunnel traffic
# should use a specific network.
# ovn_encap_ip = "10.0.0.5"
#
# Set to false if an operator or config management owns the chassis
# external_ids and the agent must never touch them.
# ovn_bootstrap_chassis = true

# TLS for an ssl: ovn_northbound endpoint. OVN deployments run a private PKI
# (ovn-pki), so the CA must be given explicitly and ovsdb-server usually
# requires a client certificate signed by the same CA — these mirror
# ovn-nbctl's -C/-c/-p flags. All paths are PEM files. This section is only
# valid when ovn_northbound is ssl:<host>:<port>.
#
# [ovn_northbound_tls]
# ca_cert = "/etc/strato/pki/cacert.pem"       # verifies the server (default: system roots)
# client_cert = "/etc/strato/pki/agent-cert.pem"
# client_key = "/etc/strato/pki/agent-privkey.pem"
# # Verify the server certificate at all (default true; lab setups only)
# verify_server_certificate = true
# # SNI/verification hostname when connecting by IP to a cert issued for a name
# server_hostname = "ovn-central.site.example"

# OVN SNAT uplink (Linux, network_mode = "ovn"). Enables outbound internet for
# networks with external access. SNAT needs a DEDICATED external IP on the
# provider network that the host does NOT own (the OVN router claims it), so it
# is explicit config, not auto-detected. Without this section, routers and
# east-west are realized but no SNAT. The operator connects `bridge` to the
# external network out of band; the agent only wires the OVN side.
#
# [ovn_uplink]
# external_cidr = "203.0.113.2/24"   # dedicated router IP on the provider net
# gateway = "203.0.113.1"            # next hop for the router's default route
# bridge = "br-ex"                   # OVS provider bridge (default br-ex)
# physnet = "physnet-strato"         # OVN physnet mapped to the bridge

# Additional configuration options can be added here as needed
# Examples:
# heartbeat_interval = 30
# max_vms = 10

# SPIFFE/SPIRE Configuration
# Enables mutual TLS authentication using SPIFFE identities
# The agent will obtain an X.509 SVID from SPIRE and use it to
# authenticate with the Control Plane over mTLS.
#
# [spiffe]
# enabled = true
#
# # Trust domain for SPIFFE identities (e.g., "strato.local")
# trust_domain = "strato.local"
#
# # Source for obtaining SVIDs:
# #   "workload_api" - Connect to SPIRE Agent's Workload API (recommended)
# #   "files" - Read certificates from files (works with spiffe-helper)
# source_type = "workload_api"
#
# # For workload_api source:
# # Path to the SPIRE Workload API Unix socket
# workload_api_socket_path = "/var/run/spire/sockets/workload.sock"
#
# # For files source:
# # Paths to certificate, key, and trust bundle files
# # These are typically written by spiffe-helper
# # certificate_path = "/var/run/spire/certs/svid.pem"
# # private_key_path = "/var/run/spire/certs/svid_key.pem"
# # trust_bundle_path = "/var/run/spire/certs/bundle.pem"

# ---------------------------------------------------------------------------
# Simulation ("dummy agent") mode — for scale-testing a control plane.
#
# When enabled, the agent registers and speaks the full agent protocol
# (register, heartbeat, desired-state reconciliation) but drives a no-op mock
# hypervisor with no real networking or storage, and reports the configurable
# fake host capacity below instead of probing the machine. This lets a fleet of
# dummy agents run on one host and load-test a control plane far larger than the
# compute available to run real VMs.
#
# The `--simulate` / `--sim-cpus` / `--sim-memory-mb` / `--sim-disk-gb` CLI
# flags override these. See agent/scripts/spawn-sim-fleet.sh to launch a whole
# fleet with a spread of host sizes.
# [simulation]
# enabled = true
#
# # Fake capacity advertised to the scheduler. Unset fields use built-in
# # defaults (8 cores / 16384 MB / 512 GB).
# cpu_cores = 16
# memory_mb = 65536
# disk_gb = 1024
