# Strato single-host deployment configuration.
#
# Don't copy this file by hand — run ./setup.sh, which generates .env with
# strong random secrets and mode 0600. This file documents the variables.

# --- Secrets (generated by setup.sh; never use example values) ---
# PostgreSQL password for the vapor_username role. Do not change after the
# database volume has been initialized.
POSTGRES_PASSWORD=
# SpiceDB gRPC preshared key, shared between SpiceDB, the schema loader, and
# the control plane.
SPICEDB_PRESHARED_KEY=
# Valkey (session storage) password.
VALKEY_PASSWORD=

# --- Hostname / WebAuthn ---
# Hostname users visit.
STRATO_HOSTNAME=localhost
# Host:port agents use to reach the control plane over mTLS — the Envoy
# listener (:8443 by default), separate from the browser proxy. Embedded in the
# bootstrap commands the UI generates. The control plane derives the SPIRE node
# address from the host part as <host>:8085.
EXTERNAL_HOSTNAME=localhost:8443
# Full origin agents fetch signed image-download URLs from. Must route to the
# control plane through the published proxy (not the in-container :8080).
CONTROL_PLANE_URL=http://localhost
# WebAuthn relying party: ID is the bare domain, origin is the exact URL in
# the browser. Passkeys are bound to these; changing them invalidates
# existing credentials. Non-localhost origins must be https://.
WEBAUTHN_RELYING_PARTY_ID=localhost
WEBAUTHN_RELYING_PARTY_NAME=Strato
WEBAUTHN_RELYING_PARTY_ORIGIN=http://localhost

# --- Service settings ---
# Host port the proxy listens on.
HTTP_PORT=80
# Host port the Envoy mTLS listener publishes (agents dial wss://host:PORT). If
# changed, keep the port in EXTERNAL_HOSTNAME in sync.
AGENT_MTLS_PORT=8443
# Host port the SPIRE server node API publishes (agents dial it for
# attestation). The control plane derives this as <EXTERNAL_HOSTNAME host>:8085,
# so leave it at 8085 unless you also adjust that derivation.
SPIRE_NODE_PORT=8085
LOG_LEVEL=info
# Strato image tag to deploy (pin to a release, e.g. v0.5.0).
STRATO_VERSION=latest
# PostgreSQL TLS mode for the control plane: disable | prefer | require. The
# bundled DB lives on this compose network and never leaves the host, so
# `disable` is the default. Set to `require` (and DATABASE_TLS_CA_CERT_PATH to
# a CA bundle mounted into the control-plane container) when pointing at an
# external database.
DATABASE_TLS=disable
